#:kivy 1.0.0

<GameBall>:
    size: 40, 40
    canvas:
        Color:
            rgba: (0.98, 0.76, 0.13, 1) if self.ball_type == 'yellow' else ((0.92, 0.26, 0.26, 1) if self.ball_type == 'red' else (0.24, 0.76, 0.43, 1))
        Ellipse:
            pos: self.pos
            size: self.size

<GamePaddle>:
    size: 160, 22
    canvas:
        Color:
            rgba: 0.0, 0.8, 1.0, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [11]

<CatchGame>:
    ball: game_ball
    paddle: game_paddle

    canvas:
        Color:
            rgba: 0.03, 0.05, 0.1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    # Очки и Рекорд сверху по центру (для удобства на смартфонах)
    Label:
        font_size: 24
        center_x: root.width / 2
        top: root.top - 20
        text: "Счёт: " + str(root.score) + "  |  Рекорд: " + str(root.highscore)
        color: 1, 1, 1, 1

    # Жизни чуть ниже счета
    Label:
        font_size: 22
        center_x: root.width / 2
        top: root.top - 60
        text: "Жизни: " + str(root.lives) + " / 3" if root.lives > 0 else "Жизни: 0"
        color: 1, 0.3, 0.3, 1

    # Краткие правила в самом низу экрана, чтобы не мешать игре
    Label:
        font_size: 14
        center_x: root.width / 2
        y: 10
        text: "желтый +1  |  зеленый +3  |  красный -3  (При -5 очках: -1 жизнь)"
        color: 0.5, 0.55, 0.65, 1

    # Текст конца игры
    Label:
        font_size: 32
        bold: True
        center: root.center
        text: root.game_over_text
        color: 1, 0.3, 0.3, 1
        halign: 'center'

    GameBall:
        id: game_ball

    GamePaddle:
        id: game_paddle
        y: 100 # Чуть приподняли ракетку повыше, чтобы палец игрока не закрывал её в самом низу экрана
        center_x: root.width / 2